# --- Identity Module ---
# AES-256 encryption key (32-byte Base64) for sensitive token storage (Gemini, GitHub)
# Generate with: python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=

# --- Authentication ---
# HS256 signing key for JWT access tokens (15-minute TTL) and is referenced at startup.
# Generate with: openssl rand -base64 64
# Never hardcoded. Never committed. A runtime-generated key would invalidate every
# outstanding token on every restart — set this explicitly before running the app.
# Production: pull from Google Secret Manager (Cloud Run target).
JWT_SIGNING_KEY=

# --- Infrastructure ---
# MongoDB Atlas connection string or local replica set URI.
# Multi-document transactions require a replica set (even single-node rs0).
# MONGODB_URI=mongodb://localhost:27017/merge?replicaSet=rs0

# Redis connection (used for refresh tokens, rate limiting, password reset tokens,
# and the registered_emails fast-path set).
# REDIS_URI=redis://localhost:6379

# --- Integrations ---
# RapidAPI Key used for calling the Judge0 CE API.
# Daily request limits (Free tier: 50 requests/day).
# Note: 50 reqs/day is insufficient for 15 concurrent active students submitting builds regularly.
RAPIDAPI_KEY=
